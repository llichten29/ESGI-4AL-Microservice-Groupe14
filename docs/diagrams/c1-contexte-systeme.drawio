  <diagram id="c1-contexte" name="C1 - Contexte systeme">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;Diagramme de contexte système (C4 — Niveau 1)&lt;/b&gt; — Plateforme de livraison de repas" style="text;html=1;align=left;verticalAlign=middle;fontSize=20;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="&lt;b&gt;Légende&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#08427B&quot;&gt;■&lt;/font&gt; Personne&amp;nbsp;&amp;nbsp;&lt;font color=&quot;#1168BD&quot;&gt;■&lt;/font&gt; Système étudié&amp;nbsp;&amp;nbsp;&lt;font color=&quot;#8C8C8C&quot;&gt;■&lt;/font&gt; Système externe" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#333333;spacing=8;strokeColor=#D0D0D0;fillColor=#FAFAFA;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="420" height="50" as="geometry" />
        </mxCell>
        <mxCell id="pClient" value="&lt;b&gt;Client&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Personne]&lt;br&gt;Parcourt les restaurants, commande des repas, paie en ligne et suit sa livraison&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;fontColor=#FFFFFF;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="pResto" value="&lt;b&gt;Restaurateur&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Personne]&lt;br&gt;Gère son profil et ses menus, accepte ou refuse les commandes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;fontColor=#FFFFFF;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="110" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="pLivreur" value="&lt;b&gt;Livreur&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Personne]&lt;br&gt;Déclare sa disponibilité, accepte les propositions et effectue les livraisons&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#052E56;fontColor=#FFFFFF;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="540" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="system" value="&lt;b&gt;Plateforme de Livraison de Repas&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Système logiciel]&lt;br&gt;Permet de commander des repas auprès de restaurants partenaires, de payer en ligne et de faire livrer par des livreurs indépendants&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0B4884;fontColor=#FFFFFF;fontSize=14;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="psp" value="&lt;b&gt;PSP — Stripe&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Système externe]&lt;br&gt;Prestataire de paiement sécurisé : autorisation, capture, remboursement&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C8C8C;strokeColor=#6B6B6B;fontColor=#FFFFFF;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="930" y="345" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="notif" value="&lt;b&gt;Fournisseurs Email / SMS / Push&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[Systèmes externes — simulés]&lt;br&gt;Acheminement des notifications aux utilisateurs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C8C8C;strokeColor=#6B6B6B;fontColor=#FFFFFF;fontSize=13;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="930" y="540" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="eClient" value="Parcourt, commande, paie, suit&lt;br&gt;[HTTPS / application mobile &amp;amp; web]" style="endArrow=classic;html=1;fontSize=11;strokeColor=#555555;fontColor=#333333;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=0.25;entryY=0;rounded=0;" edge="1" parent="1" source="pClient" target="system">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eResto" value="Gère menus et commandes&lt;br&gt;[HTTPS / portail restaurateur]" style="endArrow=classic;html=1;fontSize=11;strokeColor=#555555;fontColor=#333333;labelBackgroundColor=#FFFFFF;exitX=0;exitY=0.5;entryX=0.75;entryY=0;rounded=0;" edge="1" parent="1" source="pResto" target="system">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eLivreur" value="Accepte et effectue les livraisons&lt;br&gt;[HTTPS / application livreur]" style="endArrow=classic;html=1;fontSize=11;strokeColor=#555555;fontColor=#333333;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=0.25;entryY=1;rounded=0;" edge="1" parent="1" source="pLivreur" target="system">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ePsp" value="Autorise, capture,&lt;br&gt;rembourse [HTTPS]" style="endArrow=classic;html=1;fontSize=11;strokeColor=#555555;fontColor=#333333;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=0;entryY=0.5;rounded=0;" edge="1" parent="1" source="system" target="psp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eNotif" value="Envoie les notifications&lt;br&gt;[SMTP / API]" style="endArrow=classic;html=1;fontSize=11;strokeColor=#555555;fontColor=#333333;labelBackgroundColor=#FFFFFF;exitX=0.75;exitY=1;entryX=0;entryY=0.5;rounded=0;" edge="1" parent="1" source="system" target="notif">
          <mxGeometry relative="1" as="geometry" />

                <mxCell id="g2" value="&lt;b&gt;Service Restaurant&lt;/b&gt; — MongoDB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#4DA65D;dashed=1;verticalAlign=top;align=center;spacing=10;fontSize=13;fontColor=#3F7A4A;" parent="1" vertex="1">

                <mxCell id="rel3" value="1..*" style="endArrow=diamondThin;endFill=0;html=1;fontSize=10;strokeColor=#666666;fontColor=#333333;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.25;entryX=0;entryY=0.25;" parent="1" source="e6" target="e7" edge="1">

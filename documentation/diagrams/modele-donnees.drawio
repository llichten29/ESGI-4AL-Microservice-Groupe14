                <mxCell id="e1" value="&lt;b&gt;orders&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id : UUID (PK)&lt;br&gt;client_id : UUID&lt;br&gt;restaurant_id : UUID&lt;br&gt;statut : RECUE | EN_PREPARATION |&lt;br&gt;&amp;nbsp;&amp;nbsp;EN_LIVRAISON | LIVREE | ANNULEE&lt;br&gt;montant_plats : decimal&lt;br&gt;frais_livraison : decimal&lt;br&gt;montant_total : decimal&lt;br&gt;adresse_livraison : jsonb&lt;br&gt;created_at : timestamptz&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;fontSize=12;" parent="1" vertex="1">

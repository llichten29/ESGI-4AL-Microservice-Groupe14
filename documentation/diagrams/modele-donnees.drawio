                <mxCell id="e6" value="&lt;b&gt;couriers&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id : UUID (PK)&lt;br&gt;nom : varchar&lt;br&gt;telephone : varchar&lt;br&gt;vehicule : VELO | SCOOTER | VOITURE&lt;br&gt;statut : DISPONIBLE | EN_COURSE |&lt;br&gt;&amp;nbsp;&amp;nbsp;HORS_LIGNE&lt;br&gt;note_moyenne : decimal&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1020" y="150" width="190" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="e7" value="&lt;b&gt;deliveries&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot;&gt;id : UUID (PK)&lt;br&gt;order_id : UUID (réf. externe)&lt;br&gt;courier_id : UUID (FK)&lt;br&gt;statut : PROPOSEE | ACCEPTEE |&lt;br&gt;&amp;nbsp;&amp;nbsp;RECUPEREE | LIVREE&lt;br&gt;adresse_retrait : jsonb&lt;br&gt;adresse_livraison : jsonb&lt;br&gt;accepted_at / delivered_at&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;fontSize=12;" parent="1" vertex="1">

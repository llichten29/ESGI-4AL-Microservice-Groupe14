                <mxCell id="redisLogo" value="" style="shape=image;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="450" width="40" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="e8" value="&lt;b&gt;Redis — positions temps réel&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;clé « pos:{courier_id} » → { lat, lng, ts } — TTL 30 s&lt;br&gt;GEOADD livreurs_disponibles → recherche du livreur le plus proche du restaurant&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;align=left;verticalAlign=middle;spacing=8;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1085" y="440" width="335" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="crossNote" value="&lt;b&gt;Aucune clé étrangère entre services&lt;/b&gt; : les références inter-services (order_id, client_id, restaurant_id…) sont de simples UUID. La cohérence entre services est assurée par événements RabbitMQ (cohérence à terme / eventual consistency)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#D0D0D0;align=left;verticalAlign=middle;spacing=10;fontSize=11;fontColor=#333333;" parent="1" vertex="1">

                    <mxGeometry x="908" y="78" width="40" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="e5" value="&lt;b&gt;collection « restaurants » — 1 document = 1 agrégat&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;&lt;font style=&quot;font-size:10px&quot; face=&quot;Courier New&quot;&gt;{&lt;br&gt;&amp;nbsp;&amp;nbsp;_id, nom, typeCuisine,&lt;br&gt;&amp;nbsp;&amp;nbsp;adresse : { rue, ville, cp },&lt;br&gt;&amp;nbsp;&amp;nbsp;geo : { lat, lng },&lt;br&gt;&amp;nbsp;&amp;nbsp;horaires : [ { jour, ouverture, fermeture } ],&lt;br&gt;&amp;nbsp;&amp;nbsp;menus : [&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;{ nom,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;plats : [&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;{ _id, libelle, description,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;prix, options : [ … ],&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;disponible : bool }&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;]&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;}&lt;br&gt;&amp;nbsp;&amp;nbsp;],&lt;br&gt;&amp;nbsp;&amp;nbsp;statutOuverture, noteMoyenne&lt;br&gt;}&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="540" y="150" width="400" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="e5note" value="&lt;i&gt;Modèle documentaire : le menu complet est un agrégat unique → lecture en une seule requête, schéma flexible par restaurant (options, formules…).&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=middle;spacing=8;fontSize=10;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="540" y="505" width="400" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="g3" value="&lt;b&gt;Service Livraison&lt;/b&gt; — PostgreSQL + Redis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#B85450;dashed=1;verticalAlign=top;align=center;spacing=10;fontSize=13;fontColor=#B85450;" parent="1" vertex="1">
